{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun"],
    "baseUrl": ".",
    "paths": {
      "@compare-metrics/*": ["../scripts/compare/lib/metrics/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "*.ts", "index.html"]
}
