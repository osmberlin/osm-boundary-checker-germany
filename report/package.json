{
  "name": "report",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-areas": "bun ./generateAreasJson.ts",
    "prepare-static-snapshot": "bun ./prepareStaticSnapshot.ts",
    "sync-runtime-assets": "bun run prepare-static-snapshot && bun run generate-areas",
    "bundle-static-assets": "bun ./bundleStaticAssets.ts",
    "predev": "bun run sync-runtime-assets",
    "dev": "vite",
    "lint:react-compiler": "eslint --max-warnings=0 .",
    "build": "bun run lint:react-compiler && rm -rf dist && vite build && bun run bundle-static-assets",
    "build:with-runtime": "bun run sync-runtime-assets && bun run build",
    "preview": "vite preview",
    "report:data-sizes": "bun ./reportDataSizes.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.22",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "maplibre-gl": "^5.21.1",
    "pmtiles": "^4.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.38.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-plugin-react-compiler": "^0.3.2",
    "bun-plugin-tailwind": "^0.1.2",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  }
}
