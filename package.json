{
  "name": "osm-boundary-checker-germany",
  "private": true,
  "workspaces": [
    "scripts",
    "report"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "rust:build": "cargo build --release --manifest-path rust/geom-sidecar/Cargo.toml",
    "format": "oxfmt --write .",
    "compare": "bun run run.ts",
    "compare:boundaries": "bun run --filter ./scripts compare",
    "pipeline:nightly": "bun run pipeline:nightly:download && bun run pipeline:nightly:extract && bun run pipeline:nightly:compare",
    "pipeline:nightly:download": "bun run --filter ./scripts pipeline:nightly:download",
    "pipeline:nightly:extract": "bun run --filter ./scripts pipeline:nightly:extract",
    "pipeline:nightly:compare": "bun run --filter ./scripts pipeline:nightly:compare",
    "berlin:download": "bun run --filter ./scripts berlin:download",
    "download": "bun run download:bkg && bun run download:official && bun run download:osm",
    "download:bkg": "bun run bkg:download && bun run bkg:extract",
    "download:bkg:fetch": "bun run bkg:download",
    "download:bkg:extract": "bun run bkg:extract",
    "download:official": "bun run --filter ./scripts download:official",
    "download:osm": "bun run osm:download && bun run osm:extract",
    "download:osm:fetch": "bun run osm:download",
    "download:osm:extract": "bun run osm:extract",
    "osm": "bun run osm:download && bun run osm:extract",
    "osm:download": "bun run --filter ./scripts osm:download",
    "osm:extract": "bun run --filter ./scripts osm:extract",
    "bkg": "bun run bkg:download && bun run bkg:extract",
    "bkg:download": "bun run --filter ./scripts bkg:download",
    "bkg:extract": "bun run --filter ./scripts bkg:extract",
    "test": "bun test scripts/",
    "test:scripts": "bun run --filter ./scripts test",
    "report:dev": "bun run --filter report dev",
    "report:dev:with-rust": "bun run rust:build && bun run --filter report dev",
    "report:build": "bun run --filter report build:with-runtime",
    "report:build:app": "bun run --filter report build",
    "report:sync-runtime-assets": "bun run --filter report sync-runtime-assets",
    "report:preview": "bun run --filter report preview",
    "report:test": "bun run --filter report test",
    "report:lint:react-compiler": "bun run --filter report lint:react-compiler",
    "report:data-sizes": "bun run --filter report report:data-sizes",
    "report:data-flow-sizes": "bun run --filter ./scripts report:data-flow-sizes",
    "report:generate-areas": "bun run --filter report generate-areas",
    "german-key-lookup:update": "bun run --filter ./scripts german-key-lookup:update",
    "german-key-lookup:weekly": "bun run --filter ./scripts german-key-lookup:weekly",
    "changelog": "bun run changelog:verify && bun run changelog:build && bun run format",
    "changelog:prefill": "changelog-kit-prefill --output-json-path report/public/changelog.gen.json --ignore-commit-term \"chore(data):\"",
    "changelog:verify": "changelog-kit-verify --output-json-path report/public/changelog.gen.json --ignore-commit-term \"chore(data):\"",
    "changelog:build": "changelog-kit-build --output-json-path report/public/changelog.gen.json",
    "update:deps": "bunx taze latest --include-locked --interactive --write",
    "update:gitdeps": "bun update @tordans/changelog-kit",
    "update:app": "bun install && bun run check && bun run changelog",
    "update": "bun run update:deps && bun run update:gitdeps && bun run update:app",
    "typecheck": "tsgo -p tsconfig.json && tsgo -p scripts/tsconfig.json && tsgo -p report/tsconfig.json",
    "lint": "oxlint --fix --fix-suggestions --fix-dangerously .",
    "check": "bun run format && bun run lint && bun run typecheck && bun run report:lint:react-compiler"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@tordans/changelog-kit": "github:tordans/changelog-kit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260428.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "npm:@typescript/typescript6@^6.0.0"
  },
  "patchedDependencies": {
    "osm2geojson-ultra@4.0.1": "patches/osm2geojson-ultra@4.0.1.patch"
  }
}
