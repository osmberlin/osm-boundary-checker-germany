{
  "name": "osm-boundary-checker-germany",
  "private": true,
  "workspaces": [
    "scripts",
    "report"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "rust:build": "cargo build --release --manifest-path rust/geom-sidecar/Cargo.toml",
    "format": "oxfmt --write .",
    "typecheck": "tsgo -p tsconfig.json && tsgo -p scripts/tsconfig.json && tsgo -p report/tsconfig.json",
    "lint": "oxlint --fix --fix-suggestions --fix-dangerously .",
    "check": "bun run format && bun run lint && bun run typecheck && bun run --filter report lint:react-compiler",
    "compare": "bun run cli/compare.ts",
    "download": "bun run cli/download.ts",
    "extract": "bun run cli/extract.ts",
    "extract:osm": "bun run cli/extract-osm.ts",
    "extract:official": "bun run cli/extract-official.ts",
    "test": "bun test scripts/",
    "test:scripts": "bun run --filter ./scripts test",
    "german-key-lookup:update": "bun run --filter ./scripts german-key-lookup:update && oxfmt --write report/public/data/german-key-lookup.json",
    "german-key-lookup:weekly": "bun run --filter ./scripts german-key-lookup:weekly && oxfmt --write report/public/data/german-key-lookup.json",
    "changelog": "changelog --output-json-path report/public/changelog.gen.json --ignore-commit-term \"chore(data):\" && bun run format",
    "changelog:husky": "changelog --non-interactive --ci --validate --generate --output-json-path report/public/changelog.gen.json --ignore-commit-term \"chore(data):\"",
    "changelog:remap": "changelog --non-interactive --ci --remap-refs",
    "update": "bun run update:deps && bun run update:gitdeps && bun run update:app",
    "update:deps": "bunx taze latest --include-locked --maturity-period 5 --interactive --write",
    "update:gitdeps": "bun update @tordans/changelog-kit",
    "update:app": "bun install && bun run check && bun run changelog"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@tordans/changelog-kit": "github:tordans/changelog-kit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260511.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "npm:@typescript/typescript6@^6.0.1"
  },
  "patchedDependencies": {
    "osm2geojson-ultra@4.0.1": "patches/osm2geojson-ultra@4.0.1.patch"
  }
}
